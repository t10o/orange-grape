---
import type { SanityPost } from "@orange-grape/types";
import { urlFor } from "../lib/image";

interface Props {
  post: SanityPost;
}

const { post } = Astro.props;
const postUrl = `/blog/${post.slug.current}`;
const formattedDate = new Date(post.publishedAt).toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const thumbnailUrl = post.mainImage
  ? urlFor(post.mainImage).width(800).height(420).auto("format").url()
  : null;
---

<article
  aria-labelledby={`post-title-${post._id}`}
  class="group flex flex-col rounded-3xl neuro-raised p-5 gap-4 transition-all duration-300 hover:neuro-raised-lg"
>
  <!-- Thumbnail — pressed into the card surface -->
  {thumbnailUrl ? (
    <a
      href={postUrl}
      tabindex="-1"
      aria-hidden="true"
      class="block rounded-2xl overflow-hidden aspect-[16/9] neuro-pressed"
    >
      <img
        src={thumbnailUrl}
        alt={post.mainImage?.alt ?? ""}
        width="800"
        height="420"
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </a>
  ) : (
    <div
      class="rounded-2xl aspect-[16/9] neuro-pressed overflow-hidden flex items-center justify-center"
    >
      <span class="text-4xl font-black gradient-text-primary opacity-30 select-none">OG</span>
    </div>
  )}

  <!-- Content -->
  <div class="flex flex-col flex-1 gap-3 px-1">
    <!-- Categories -->
    {post.categories && post.categories.length > 0 && (
      <ul class="flex flex-wrap gap-2 list-none" aria-label="カテゴリ">
        {post.categories.map((cat, i) => (
          <li>
            <a
              href={`/category/${cat.slug.current}`}
              class={[
                "inline-flex items-center px-3 py-0.5 rounded-full text-xs font-bold neuro-raised-sm transition-all duration-200 active:neuro-pressed-sm",
                i % 2 === 0
                  ? "text-primary-600"
                  : "text-secondary-600",
              ].join(" ")}
            >
              {cat.title}
            </a>
          </li>
        ))}
      </ul>
    )}

    <!-- Title -->
    <h2
      id={`post-title-${post._id}`}
      class="text-lg font-bold leading-snug tracking-tight"
    >
      <a
        href={postUrl}
        class="neuro-text hover:text-primary-600 transition-colors duration-200"
      >
        {post.title}
      </a>
    </h2>

    <!-- Excerpt -->
    {post.excerpt && (
      <p class="text-sm neuro-muted line-clamp-2 leading-relaxed">
        {post.excerpt}
      </p>
    )}

    <!-- Meta -->
    <div class="flex items-center gap-3 mt-auto pt-3 text-xs neuro-muted">
      <!-- Divider line (pressed) -->
      <div
        class="h-px flex-1 rounded-full"
        style="box-shadow: inset 0 1px 2px var(--neuro-dark), inset 0 -1px 1px var(--neuro-light);"
      />
      <time datetime={post.publishedAt}>{formattedDate}</time>
      {post.author && (
        <>
          <span aria-hidden="true">·</span>
          <span>{post.author.name}</span>
        </>
      )}
    </div>
  </div>
</article>
