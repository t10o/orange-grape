---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  jsonLd?: object | object[];
  article?: {
    publishedTime: string;
    modifiedTime: string;
    author: string;
  };
}

const { title, description, ogImage, canonical, jsonLd, article } = Astro.props;

const siteUrl = import.meta.env.SITE_URL ?? "https://example.com";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage ?? `${siteUrl}/og-default.png`;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const adsenseId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID;

const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : null;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OGP -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Orage Grape" />
    <meta property="og:locale" content="ja_JP" />
    {article && (
      <>
        <meta property="article:published_time" content={article.publishedTime} />
        <meta property="article:modified_time" content={article.modifiedTime} />
        <meta property="article:author" content={article.author} />
      </>
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD -->
    {jsonLdArray && jsonLdArray.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Google Analytics 4 -->
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag("js", new Date());
          gtag("config", gaId);
        </script>
      </>
    )}

    <!-- Google AdSense -->
    {adsenseId && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseId}`}
        crossorigin="anonymous"
      />
    )}
  </head>
  <body class="min-h-screen font-sans antialiased">
    <!-- Skip navigation -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary-500 focus:text-white focus:rounded-2xl"
    >
      コンテンツへスキップ
    </a>

    <!-- Header -->
    <header role="banner" class="sticky top-0 z-40">
      <slot name="header">
        <nav
          aria-label="サイトナビゲーション"
          class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between gap-6"
          style="background: var(--neuro-bg); box-shadow: 0 4px 12px var(--neuro-dark), 0 -1px 4px var(--neuro-light);"
        >
          <!-- Logo -->
          <a
            href="/"
            aria-label="Orage Grape ホームへ"
            class="shrink-0"
          >
            <span class="text-xl font-extrabold tracking-tight gradient-text-primary select-none">
              Orage Grape
            </span>
          </a>

          <!-- Nav links -->
          <ul class="flex items-center gap-3 list-none" role="list">
            <li>
              <a
                href="/"
                class="px-4 py-1.5 rounded-2xl text-sm font-medium neuro-muted hover:neuro-text neuro-raised-sm transition-all duration-200 active:neuro-pressed-sm"
              >
                ホーム
              </a>
            </li>
          </ul>
        </nav>
      </slot>
    </header>

    <!-- Main -->
    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer role="contentinfo" class="mt-24">
      <div
        class="max-w-5xl mx-auto mx-6 px-6 py-10 rounded-t-3xl neuro-pressed"
      >
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <a href="/" class="text-lg font-bold gradient-text-primary">
            Orage Grape
          </a>
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="/privacy-policy" class="text-sm neuro-muted hover:neuro-text transition-colors">
              プライバシーポリシー
            </a>
            <p class="text-sm neuro-muted">
              &copy; {new Date().getFullYear()} Orage Grape. All rights reserved.
            </p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
