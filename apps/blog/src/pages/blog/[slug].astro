---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { urlFor } from "../../lib/image";
import { articleSchema, breadcrumbSchema } from "../../lib/jsonld";
import { renderPortableText } from "../../lib/portableText";
import { getAllSlugs, getPostBySlug } from "../../lib/queries";

export const getStaticPaths: GetStaticPaths = async () => {
  const slugs = await getAllSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
};

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");
const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/404");
}

const siteUrl = import.meta.env.SITE_URL ?? "https://example.com";
const ogImage = post.mainImage
  ? urlFor(post.mainImage).width(1200).height(630).auto("format").url()
  : undefined;

const jsonLd = [
  articleSchema({
    title: post.title,
    excerpt: post.excerpt,
    slug: post.slug.current,
    publishedAt: post.publishedAt,
    updatedAt: post._updatedAt,
    authorName: post.author?.name ?? "Anonymous",
    imageUrl: ogImage,
  }),
  breadcrumbSchema([
    { name: "ホーム", url: siteUrl },
    { name: "ブログ", url: `${siteUrl}/blog` },
    { name: post.title, url: `${siteUrl}/blog/${post.slug.current}` },
  ]),
];

const formattedDate = new Date(post.publishedAt).toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  ogImage={ogImage}
  article={{
    publishedTime: post.publishedAt,
    modifiedTime: post._updatedAt,
    author: post.author?.name ?? "Anonymous",
  }}
  jsonLd={jsonLd}
>
  <div class="max-w-3xl mx-auto px-6">
    <!-- Breadcrumb -->
    <nav aria-label="パンくず" class="pt-8 pb-2">
      <ol
        class="flex flex-wrap items-center gap-1.5 text-xs list-none"
        itemscope
        itemtype="https://schema.org/BreadcrumbList"
      >
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/" class="neuro-muted hover:text-primary-500 transition-colors">
            <span itemprop="name">ホーム</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <li aria-hidden="true" class="neuro-muted">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/blog" class="neuro-muted hover:text-primary-500 transition-colors">
            <span itemprop="name">ブログ</span>
          </a>
          <meta itemprop="position" content="2" />
        </li>
        <li aria-hidden="true" class="neuro-muted">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" class="neuro-text line-clamp-1">{post.title}</span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </nav>

    <article
      aria-labelledby="post-title"
      itemscope
      itemtype="https://schema.org/Article"
    >
      <!-- Header -->
      <header class="pt-8 pb-10">
        {post.categories && post.categories.length > 0 && (
          <ul class="flex flex-wrap gap-2 list-none mb-5" aria-label="カテゴリ">
            {post.categories.map((cat, i) => (
              <li>
                <a
                  href={`/category/${cat.slug.current}`}
                  class={[
                    "inline-flex items-center px-3 py-1 rounded-full text-xs font-bold neuro-raised-sm transition-all duration-200 active:neuro-pressed-sm",
                    i % 2 === 0
                      ? "text-primary-600"
                      : "text-secondary-600",
                  ].join(" ")}
                >
                  {cat.title}
                </a>
              </li>
            ))}
          </ul>
        )}

        <h1
          id="post-title"
          class="text-3xl sm:text-4xl font-extrabold leading-tight tracking-tight neuro-text mb-5"
        >
          {post.title}
        </h1>

        <div class="flex items-center gap-3 text-sm neuro-muted">
          <time datetime={post.publishedAt} itemprop="datePublished">{formattedDate}</time>
          {post.author && (
            <>
              <span aria-hidden="true">·</span>
              <span itemprop="author" itemscope itemtype="https://schema.org/Person">
                <span itemprop="name">{post.author.name}</span>
              </span>
            </>
          )}
        </div>
      </header>

      <!-- Hero image — pressed into the page surface -->
      {post.mainImage && ogImage && (
        <figure class="mb-10 rounded-3xl overflow-hidden neuro-pressed">
          <img
            src={ogImage}
            alt={post.mainImage.alt ?? ""}
            width="1200"
            height="630"
            loading="eager"
            fetchpriority="high"
            style="aspect-ratio: 1200/630"
            class="w-full object-cover"
          />
        </figure>
      )}

      <!-- AdSense: 記事上 -->
      <div
        class="ad-slot my-10 rounded-3xl neuro-pressed flex items-center justify-center"
        aria-label="広告"
      />

      <!-- Article body -->
      <div
        class="rounded-3xl neuro-raised p-8 sm:p-10
          prose prose-base max-w-none
          prose-headings:neuro-text prose-headings:font-bold prose-headings:tracking-tight
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:leading-relaxed prose-p:neuro-text
          prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline
          prose-strong:neuro-text
          prose-code:text-secondary-700 prose-code:bg-secondary-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-lg prose-code:text-sm prose-code:font-medium
          prose-pre:rounded-2xl
          prose-img:rounded-2xl
          prose-blockquote:border-l-primary-400 prose-blockquote:neuro-muted prose-blockquote:not-italic
          dark:prose-invert
          dark:prose-a:text-primary-400
          dark:prose-code:text-secondary-300 dark:prose-code:bg-secondary-950"
        set:html={renderPortableText(post.body)}
      />

      <!-- AdSense: 記事下 -->
      <div
        class="ad-slot mt-10 rounded-3xl neuro-pressed flex items-center justify-center"
        aria-label="広告"
      />

      <!-- Back link -->
      <div class="mt-12 pb-16">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-2xl text-sm font-medium neuro-raised-sm neuro-muted hover:text-primary-600 transition-all duration-200 active:neuro-pressed-sm"
        >
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          記事一覧へ戻る
        </a>
      </div>
    </article>
  </div>
</BaseLayout>
