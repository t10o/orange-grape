---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { urlFor } from "../../lib/image";
import { articleSchema, breadcrumbSchema } from "../../lib/jsonld";
import { renderPortableText } from "../../lib/portableText";
import { getAllSlugs, getPostBySlug } from "../../lib/queries";

export const getStaticPaths: GetStaticPaths = async () => {
  const slugs = await getAllSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
};

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");
const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/404");
}

const siteUrl = import.meta.env.SITE_URL ?? "https://example.com";
const ogImage = post.mainImage
  ? urlFor(post.mainImage).width(1200).height(630).auto("format").url()
  : undefined;

const jsonLd = [
  articleSchema({
    title: post.title,
    excerpt: post.excerpt,
    slug: post.slug.current,
    publishedAt: post.publishedAt,
    updatedAt: post._updatedAt,
    authorName: post.author?.name ?? "Anonymous",
    imageUrl: ogImage,
  }),
  breadcrumbSchema([
    { name: "ホーム", url: siteUrl },
    { name: "ブログ", url: `${siteUrl}/blog` },
    { name: post.title, url: `${siteUrl}/blog/${post.slug.current}` },
  ]),
];

const formattedDate = new Date(post.publishedAt).toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  ogImage={ogImage}
  article={{
    publishedTime: post.publishedAt,
    modifiedTime: post._updatedAt,
    author: post.author?.name ?? "Anonymous",
  }}
  jsonLd={jsonLd}
>
  <article
    aria-labelledby="post-title"
    class="max-w-3xl mx-auto px-4 py-12"
    itemscope
    itemtype="https://schema.org/Article"
  >
    <!-- Hero image -->
    {post.mainImage && ogImage && (
      <figure class="mb-8 -mx-4 sm:mx-0">
        <img
          src={ogImage}
          alt={post.mainImage.alt ?? ""}
          width="1200"
          height="630"
          loading="eager"
          fetchpriority="high"
          style="aspect-ratio: 1200/630"
          class="w-full rounded-lg object-cover"
        />
      </figure>
    )}

    <!-- Header -->
    <header class="mb-8">
      {post.categories && post.categories.length > 0 && (
        <ul class="flex flex-wrap gap-2 list-none mb-3" aria-label="カテゴリ">
          {post.categories.map((cat) => (
            <li>
              <a
                href={`/category/${cat.slug.current}`}
                class="text-sm font-medium text-brand-600 hover:text-brand-700"
              >
                {cat.title}
              </a>
            </li>
          ))}
        </ul>
      )}

      <h1 id="post-title" class="text-3xl sm:text-4xl font-bold leading-tight mb-4">
        {post.title}
      </h1>

      <div class="flex items-center gap-4 text-sm text-gray-500">
        <time datetime={post.publishedAt} itemprop="datePublished">
          {formattedDate}
        </time>
        {post.author && (
          <span itemprop="author" itemscope itemtype="https://schema.org/Person">
            <span itemprop="name">by {post.author.name}</span>
          </span>
        )}
      </div>
    </header>

    <!-- AdSense: 記事上 -->
    <div class="ad-slot my-8" aria-label="広告">
      <!-- AdSense slot will be added here after approval -->
    </div>

    <!-- Article body -->
    <div class="prose prose-gray dark:prose-invert max-w-none" set:html={renderPortableText(post.body)} />

    <!-- AdSense: 記事下 -->
    <div class="ad-slot mt-8" aria-label="広告">
      <!-- AdSense slot will be added here after approval -->
    </div>

    <!-- Footer -->
    <footer class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-800">
      <nav aria-label="パンくず" class="text-sm text-gray-500">
        <ol class="flex flex-wrap gap-1 list-none" itemscope itemtype="https://schema.org/BreadcrumbList">
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a itemprop="item" href="/" class="hover:text-brand-600">
              <span itemprop="name">ホーム</span>
            </a>
            <meta itemprop="position" content="1" />
          </li>
          <li aria-hidden="true">/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a itemprop="item" href="/blog" class="hover:text-brand-600">
              <span itemprop="name">ブログ</span>
            </a>
            <meta itemprop="position" content="2" />
          </li>
          <li aria-hidden="true">/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name">{post.title}</span>
            <meta itemprop="position" content="3" />
          </li>
        </ol>
      </nav>
    </footer>
  </article>
</BaseLayout>
