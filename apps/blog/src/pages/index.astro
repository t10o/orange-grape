---
import PostCard from "../components/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { websiteSchema } from "../lib/jsonld";
import { getAllPosts } from "../lib/queries";

const posts = await getAllPosts();
const jsonLd = websiteSchema();
---

<BaseLayout
  title="Orage Grape — ブログ"
  description="テクノロジー・デザイン・ライフスタイルについて書くブログです。"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section aria-label="ブログ紹介" class="max-w-5xl mx-auto px-6 pt-16 pb-10">
    <div class="rounded-4xl neuro-pressed p-10 sm:p-14">
      <p class="text-xs font-bold tracking-widest uppercase text-primary-500 mb-4">
        Welcome to
      </p>
      <h1 class="text-5xl sm:text-7xl font-black tracking-tight leading-none mb-6">
        <span class="gradient-text-primary">Orage Grape</span>
      </h1>
      <p class="text-base sm:text-lg neuro-muted max-w-md leading-relaxed">
        テクノロジー・デザイン・ライフスタイルについて、<br class="hidden sm:inline" />
        日々の発見をゆるやかに綴ります。
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="max-w-5xl mx-auto px-6 pb-16" aria-label="記事一覧">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="text-xl font-bold tracking-tight neuro-text">最新記事</h2>
      <!-- Decorative rule -->
      <div
        class="h-px flex-1 rounded-full"
        style="box-shadow: inset 0 1px 2px var(--neuro-dark), inset 0 -1px 1px var(--neuro-light);"
      />
    </div>

    {posts.length === 0 ? (
      <div class="rounded-3xl neuro-pressed flex items-center justify-center py-24">
        <p class="neuro-muted text-sm">まだ記事がありません。</p>
      </div>
    ) : (
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
