---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getAllPosts } from "../lib/queries";
import { websiteSchema } from "../lib/jsonld";

const posts = await getAllPosts();
const jsonLd = websiteSchema();
---

<BaseLayout
  title="orange-grape — ブログ"
  description="テクノロジー・デザイン・ライフスタイルについて書くブログです。"
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-8">最新記事</h1>

    {posts.length === 0 ? (
      <p class="text-gray-500">記事がまだありません。</p>
    ) : (
      <ul class="grid gap-10 sm:grid-cols-2" role="list">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
